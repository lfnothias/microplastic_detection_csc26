    family-names: Nothias
    email: louisfelix.nothias@gmail.com
# Add yourself here when you contribute (name, optional affiliation/orcid).
version: 0.1.0
license: AGPL-3.0-or-later
repository-code: "https://github.com/HolobiomicsLab/CorSeaCare_yolo"
keywords:
  - marine litter
  - microplastics
  - citizen science
  - object detection
  - computer vision
